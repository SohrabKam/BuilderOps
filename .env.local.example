# Copy to .env.local and fill in real values. Never commit .env.local.

# Database — Neon Postgres connection string.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&channel_binding=require"

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Signing secret for the /api/webhooks/clerk endpoint (Clerk Dashboard → Webhooks).
# The route fails closed (500) until this is set.
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Resend — https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=notices@yourdomain.com
# Signing secret for the /api/webhooks/resend delivery-events endpoint (Resend
# Dashboard → Webhooks). The route fails closed (500) until this is set.
RESEND_WEBHOOK_SECRET=

# Inngest — https://app.inngest.com (background compliance sweep jobs)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Inbound email webhook — must match the secret configured on the inbound
# email provider's webhook (e.g. Resend inbound routing) sending to /api/inbound.
INBOUND_WEBHOOK_SECRET=

# Vercel Blob — auto-injected by Vercel when a Blob store is linked to the
# project; only needs setting by hand for local dev (Vercel dashboard →
# Storage → your Blob store → .env.local tab).
BLOB_READ_WRITE_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional — receives an email if a background job (Inngest sweep) fails.
OPS_ALERT_EMAIL=
